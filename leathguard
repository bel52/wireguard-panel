#!/bin/bash
# LeathGuard CLI
# Global management command for LeathGuard WireGuard Panel
#
# Usage: leathguard <command> [options]

set -e

VERSION="6.3.0"
INSTALL_DIR="/opt/wg-panel"

# Contract library: prefer installed copy, fall back to repo copy
for _lib in /usr/local/lib/leathguard/contract.sh "$INSTALL_DIR/lib/contract.sh"; do
    if [[ -f "$_lib" ]]; then
        # shellcheck disable=SC1090
        source "$_lib"
        lg_load_contract || true
        break
    fi
done

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Check installation
check_install() {
    if [[ ! -d "$INSTALL_DIR" ]]; then
        echo -e "${RED}LeathGuard not installed at $INSTALL_DIR${NC}"
        echo "Install with: git clone https://github.com/bel52/wireguard-panel.git $INSTALL_DIR && cd $INSTALL_DIR && sudo ./install.sh"
        exit 1
    fi
}

# Commands
cmd_doctor() {
    check_install
    lg_doctor "$@"
}

cmd_adopt() {
    # Generate /etc/leathguard/env.conf from detected reality on this box.
    # The contract DESCRIBES the box; it does not move anything. Off-convention
    # findings are reported as recommendations.
    check_install
    if [[ $EUID -ne 0 ]]; then echo "Run as root: sudo leathguard adopt"; exit 1; fi

    echo "Detecting this box's environment..."
    local svc; svc=$(lg_detect_service)
    [[ -n "$svc" ]] || { echo "Could not detect a wg-panel service unit"; exit 1; }
    lg_detect_from_unit "$svc" || { echo "Could not parse unit file for $svc"; exit 1; }
    local iface; iface=$(lg_detect_interface)
    if [[ -z "$iface" ]]; then
        echo "Multiple/zero WireGuard interfaces and none declared in the unit."
        read -rp "Which interface does this panel manage? " iface
    fi
    local cdir="/etc/wireguard/${iface}_clients"

    mkdir -p "$LG_CONF_DIR"
    cat > "$LG_CONF" <<EOF
# LeathGuard environment contract - generated by 'leathguard adopt' $(date -u +%Y-%m-%dT%H:%MZ)
# One file per box. Tooling reads this instead of guessing. Edit deliberately;
# 'leathguard doctor' verifies reality still matches.
INSTALL_DIR="$INSTALL_DIR"
APP_ENTRY="${DET_APP_ENTRY}"
SERVICE_NAME="$svc"
PANEL_PORT="${DET_PORT:-5000}"
WG_INTERFACE="$iface"
CLIENT_DIR="$cdir"
VENV_DIR="${DET_VENV}"
# Auto-update stagger for this box (24h clock, local time)
UPDATE_HOUR="3"
UPDATE_MINUTE="0"
# Optional: Pushover notifications for update outcomes
PUSHOVER_TOKEN=""
PUSHOVER_USER=""
EOF
    chmod 600 "$LG_CONF"
    echo "Contract written: $LG_CONF"
    echo ""
    # Reload and verify immediately
    lg_load_contract
    lg_doctor || {
        echo ""
        echo "Adopt complete but doctor found blocking issues - fix them (or run"
        echo "'sudo leathguard doctor --fix' for self-healable ones) before updating."
        exit 1
    }
}

cmd_auto_update() {
    # leathguard auto-update enable|disable|status
    if [[ $EUID -ne 0 && "$1" != "status" ]]; then echo "Run as root"; exit 1; fi
    local cron_file="/etc/cron.d/leathguard-autoupdate"
    case "${1:-status}" in
        enable)
            [[ -f "$LG_CONF" ]] || { echo "No contract - run: sudo leathguard adopt"; exit 1; }
            lg_doctor >/dev/null || { echo "Doctor reports blocking failures - fix before enabling unattended updates (sudo leathguard doctor)"; exit 1; }
            cat > "$cron_file" <<EOF
# LeathGuard unattended update (managed by 'leathguard auto-update')
# Staggered per box via UPDATE_HOUR/UPDATE_MINUTE in $LG_CONF
${UPDATE_MINUTE} ${UPDATE_HOUR} * * * root cd $INSTALL_DIR && ./update.sh --unattended >> /var/log/leathguard-update.log 2>&1
EOF
            chmod 644 "$cron_file"
            echo "Auto-update ENABLED: daily at ${UPDATE_HOUR}:$(printf '%02d' "$UPDATE_MINUTE") (log: /var/log/leathguard-update.log)"
            if [[ -z "$PUSHOVER_TOKEN" ]]; then
                echo "NOTE: Pushover not configured in $LG_CONF - unattended failures will only appear in the log. Strongly recommended to set PUSHOVER_TOKEN/PUSHOVER_USER."
            fi
            ;;
        disable)
            rm -f "$cron_file"
            echo "Auto-update DISABLED"
            ;;
        status|*)
            if [[ -f "$cron_file" ]]; then
                echo "Auto-update: ENABLED"; grep -v '^#' "$cron_file" | grep -v '^$'
            else
                echo "Auto-update: disabled"
            fi
            ;;
    esac
}

cmd_update() {
    check_install
    cd "$INSTALL_DIR"
    exec ./update.sh "$@"
}

cmd_status() {
    check_install
    cd "$INSTALL_DIR"
    exec ./status.sh "$@"
}

cmd_check() {
    check_install
    cd "$INSTALL_DIR"
    exec ./update.sh --check
}

cmd_restart() {
    echo "Restarting LeathGuard..."
    systemctl restart wg-panel
    sleep 2
    if systemctl is-active --quiet wg-panel; then
        echo -e "${GREEN}LeathGuard restarted successfully${NC}"
    else
        echo -e "${RED}Failed to restart. Check: sudo journalctl -u wg-panel -n 50${NC}"
        exit 1
    fi
}

cmd_stop() {
    echo "Stopping LeathGuard..."
    systemctl stop wg-panel
    echo "Stopped."
}

cmd_start() {
    echo "Starting LeathGuard..."
    systemctl start wg-panel
    sleep 2
    if systemctl is-active --quiet wg-panel; then
        echo -e "${GREEN}LeathGuard started${NC}"
    else
        echo -e "${RED}Failed to start. Check: sudo journalctl -u wg-panel -n 50${NC}"
        exit 1
    fi
}

cmd_logs() {
    local lines="${1:-50}"
    journalctl -u wg-panel -n "$lines" --no-pager
}

cmd_logs_follow() {
    journalctl -u wg-panel -f
}

cmd_version() {
    if [[ -f "$INSTALL_DIR/VERSION" ]]; then
        cat "$INSTALL_DIR/VERSION"
    else
        echo "unknown"
    fi
}

cmd_help() {
    echo -e "${CYAN}LeathGuard CLI v${VERSION}${NC}"
    echo ""
    echo "Usage: leathguard <command> [options]"
    echo ""
    echo "Commands:"
    echo "  update          Update to latest version"
    echo "  check           Check for updates without applying"
    echo "  status          Show installation status"
    echo "  adopt           Generate this box's environment contract (env.conf)"
    echo "  doctor [--fix]  Verify box matches its contract (preflight)"
    echo "  auto-update <enable|disable|status>  Manage unattended updates"
    echo "  restart         Restart the service"
    echo "  start           Start the service"
    echo "  stop            Stop the service"
    echo "  logs [n]        Show last n log lines (default: 50)"
    echo "  logs -f         Follow logs in real-time"
    echo "  version         Show installed version"
    echo "  help            Show this help"
    echo ""
    echo "Examples:"
    echo "  sudo leathguard update      # Update to latest"
    echo "  sudo leathguard check       # Check for updates"
    echo "  leathguard status           # Show status"
    echo "  sudo leathguard logs 100    # Show last 100 log lines"
    echo "  sudo leathguard logs -f     # Follow logs"
}

# Main
case "${1:-help}" in
    update)     shift; cmd_update "$@" ;;
    check)      cmd_check ;;
    doctor)     shift; cmd_doctor "$@" ;;
    adopt)      shift; cmd_adopt "$@" ;;
    auto-update) shift; cmd_auto_update "$@" ;;
    status)     cmd_status ;;
    restart)    cmd_restart ;;
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    logs)
        if [[ "${2:-}" == "-f" ]]; then
            cmd_logs_follow
        else
            cmd_logs "${2:-50}"
        fi
        ;;
    version|-v|--version)   cmd_version ;;
    help|-h|--help)         cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'leathguard help' for usage"
        exit 1
        ;;
esac
